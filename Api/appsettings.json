{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "AuthService",
    "Audience": "AuthService.Client",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "JWT_SIGNING_KEY": "development-signing-key-change-before-production",
  "Security": {
    "PasswordHashIterations": 100000
  },
  "AllowedHosts": "*"
}
