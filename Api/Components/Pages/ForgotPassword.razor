@page "/forgot-password"
@attribute [AllowAnonymous]
@inject IPasswordResetService PasswordResetService
@inject ITenantService TenantService
@inject INotificationService NotificationService
@inject IAuditService AuditService
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Forgot Password</PageTitle>

<section class="page narrow">
    <div class="panel stack">
        <p class="eyebrow">Password Reset</p>
        <h1>Request a password reset</h1>
        <p class="muted">Enter the tenant id and email address. If the account exists, a reset email will be sent.</p>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert success">@_message</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" class="stack">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <label class="field">
                <span>Tenant Id</span>
                <InputText @bind-Value="_model.TenantId" />
            </label>
            <label class="field">
                <span>Email</span>
                <InputText @bind-Value="_model.Email" />
            </label>
            <button class="button primary" type="submit" disabled="@_submitting">Send reset email</button>
        </EditForm>

        <div class="inline-links">
            <a href="/login">Back to login</a>
        </div>
    </div>
</section>

@code {
    private readonly ForgotPasswordModel _model = new();
    private bool _submitting;
    private string? _message;

    private async Task HandleSubmitAsync()
    {
        _submitting = true;
        _message = null;

        try
        {
            var reset = await PasswordResetService.CreateResetRequestAsync(_model.TenantId, _model.Email);
            if (reset.Created && reset.ResetToken is not null && reset.ExpiresAtUtc.HasValue && reset.User is not null)
            {
                var tenant = await TenantService.GetByIdAsync(_model.TenantId);
                var resetUrl = $"{NavigationManager.BaseUri.TrimEnd('/')}/reset-password?tenantId={Uri.EscapeDataString(_model.TenantId)}&token={Uri.EscapeDataString(reset.ResetToken)}";
                await NotificationService.SendPasswordResetAsync(reset.User, _model.TenantId, tenant?.Name ?? _model.TenantId, reset.ResetToken, resetUrl, reset.ExpiresAtUtc.Value);
            }

            var httpContext = HttpContextAccessor.HttpContext;
            await AuditService.LogEventAsync(
                _model.TenantId,
                null,
                "forgot_password_ui",
                "success",
                httpContext?.Connection.RemoteIpAddress?.ToString(),
                httpContext?.Request.Headers.UserAgent.ToString(),
                null);

            _message = "If the account exists, a reset request has been created.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class ForgotPasswordModel
    {
        [Required]
        public string TenantId { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
