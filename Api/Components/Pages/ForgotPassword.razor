@page "/forgot-password"
@attribute [AllowAnonymous]
@inject IPasswordResetService PasswordResetService
@inject INotificationService NotificationService
@inject IAuditService AuditService
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Forgot Password</PageTitle>

<section class="page narrow">
    <div class="panel stack">
        <p class="eyebrow">Password Reset</p>
        <h1>Request a password reset</h1>
        <p class="muted">Enter your account email address. If the account exists, a reset email will be sent.</p>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert success">@_message</div>
        }

        @if (_submitting)
        {
            <div class="activity-indicator page-loading" role="status" aria-live="polite">
                <span class="spinner" aria-hidden="true"></span>
                <div>
                    <strong>Preparing reset email</strong>
                    <div class="muted">Checking the account and creating a secure reset request.</div>
                </div>
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" class="stack">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <label class="field">
                <span>Email</span>
                <InputText @bind-Value="_model.Email" />
            </label>
            <button class="button primary" type="submit" disabled="@_submitting">Send reset email</button>
        </EditForm>

        <div class="inline-links">
            <a href="/login">Back to login</a>
        </div>
    </div>
</section>

@code {
    private readonly ForgotPasswordModel _model = new();
    private bool _submitting;
    private string? _message;

    private async Task HandleSubmitAsync()
    {
        _submitting = true;
        _message = null;

        try
        {
            var reset = await PasswordResetService.CreateResetRequestAsync(_model.Email);
            if (reset.Created && reset.ResetToken is not null && reset.ExpiresAtUtc.HasValue && reset.User is not null)
            {
                var resetUrl = $"{NavigationManager.BaseUri.TrimEnd('/')}/reset-password?token={Uri.EscapeDataString(reset.ResetToken)}";
                await NotificationService.SendPasswordResetAsync(reset.User, null, reset.ResetToken, resetUrl, reset.ExpiresAtUtc.Value);
            }

            var httpContext = HttpContextAccessor.HttpContext;
            await AuditService.LogEventAsync(
                "SYSTEM",
                null,
                "forgot_password_ui",
                "success",
                httpContext?.Connection.RemoteIpAddress?.ToString(),
                httpContext?.Request.Headers.UserAgent.ToString(),
                null);

            _message = "If the account exists, a reset request has been created.";
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class ForgotPasswordModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
