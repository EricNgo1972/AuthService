@page "/login"
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IPasskeyService PasskeyService
@implements IAsyncDisposable

<PageTitle>Login</PageTitle>

<section class="page narrow">
    <div class="panel stack">
        <p class="eyebrow">Sign In</p>
        <h1>Access the admin console</h1>
        <p class="muted">Login with your global email and password, or sign in using your phone biometric. Single-tenant users go straight in. Multi-tenant users select a tenant next.</p>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="alert error">@Error</div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert success">@Message</div>
        }

        <form method="post" action="@($"{UiSessionEndpoints.RoutePrefix}/login")" class="stack">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <label class="field">
                <span>Email</span>
                <input name="email" autocomplete="username" />
            </label>
            <label class="field">
                <span>Password</span>
                <input type="password" name="password" autocomplete="current-password" />
            </label>
            <button class="button primary" type="submit">Sign in</button>
        </form>

        <div class="inline-links">
            <a href="/forgot-password">Forgot password</a>
            <button type="button" class="button secondary phone-login-button" @onclick="TogglePasskeyAsync">Log with your phone</button>
        </div>

        @if (ShowPasskeyQr && !string.IsNullOrWhiteSpace(PasskeyRequestId))
        {
            <div class="passkey-panel stack">
                <div class="passkey-panel-header">
                    <div>
                        <p class="eyebrow">Phone Login</p>
                        <h2>Scan with your phone</h2>
                    </div>
                    <button type="button" class="button secondary" @onclick="HidePasskeyAsync">Close</button>
                </div>
                <p class="muted">Open your phone camera, scan the QR code, and approve the biometric prompt on your phone. This screen will finish the login automatically.</p>
                <img class="passkey-qr" src="@PasskeyQrImageUrl" alt="Passkey login QR code" />
                <div class="passkey-status">@PasskeyStatus</div>
            </div>
        }

    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Message { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private bool ShowPasskeyQr { get; set; }
    private string? PasskeyRequestId { get; set; }
    private string? PasskeyQrImageUrl { get; set; }
    private string PasskeyStatus { get; set; } = string.Empty;
    private string DesktopDebugLog { get; set; } = "Debug log started.";
    private CancellationTokenSource? _passkeyPollingCts;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/", true);
        }

        ReturnUrl = NormalizeReturnUrl(ReturnUrl);
    }

    private async Task TogglePasskeyAsync()
    {
        if (ShowPasskeyQr)
        {
            await HidePasskeyAsync();
            return;
        }

        await StartPasskeyAsync();
    }

    private async Task StartPasskeyAsync()
    {
        await HidePasskeyAsync();
        AppendDebug("Creating internal phone-login request.");
        var request = await PasskeyService.CreateLoginRequestAsync(null, AuthService.Application.Interfaces.PasskeyRequestMode.InternalUi);
        PasskeyRequestId = request.RequestId;
        PasskeyQrImageUrl = $"/passkey/qr/image?rid={Uri.EscapeDataString(request.RequestId)}";
        PasskeyStatus = $"Waiting for approval. Expires at {request.ExpiresAtUtc.LocalDateTime:t}.";
        ShowPasskeyQr = true;
        AppendDebug($"Phone-login request created. RequestId={request.RequestId}, ExpiresAt={request.ExpiresAtUtc:O}");

        _passkeyPollingCts = new CancellationTokenSource();
        _ = PollPasskeyStatusAsync(request.RequestId, _passkeyPollingCts.Token);
    }

    private async Task HidePasskeyAsync()
    {
        if (_passkeyPollingCts is not null)
        {
            await _passkeyPollingCts.CancelAsync();
            _passkeyPollingCts.Dispose();
            _passkeyPollingCts = null;
        }

        ShowPasskeyQr = false;
        PasskeyRequestId = null;
        PasskeyQrImageUrl = null;
        PasskeyStatus = string.Empty;
        AppendDebug("QR panel hidden and polling cancelled.");
    }

    private async Task PollPasskeyStatusAsync(string requestId, CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                AppendDebug($"Polling request status. RequestId={requestId}");
                var request = await PasskeyService.GetLoginRequestAsync(requestId, cancellationToken);
                if (request is null)
                {
                    await InvokeAsync(() =>
                    {
                        PasskeyStatus = "Passkey login request was not found.";
                        AppendDebug("Poll result: request not found.");
                        StateHasChanged();
                    });
                    return;
                }

                AppendDebug($"Poll result: Status={request.Status}, ExpiresAt={request.ExpiresAtUtc:O}, UserId={request.UserId ?? "(null)"}");

                if (string.Equals(request.Status, "Approved", StringComparison.OrdinalIgnoreCase))
                {
                    AppendDebug("Request approved. Redirecting to UI session completion route.");
                    await InvokeAsync(() => NavigationManager.NavigateTo($"{UiSessionEndpoints.RoutePrefix}/passkey-complete?rid={Uri.EscapeDataString(requestId)}&returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/manage")}", true));
                    return;
                }

                if (string.Equals(request.Status, "Expired", StringComparison.OrdinalIgnoreCase))
                {
                    await InvokeAsync(() =>
                    {
                        PasskeyStatus = "Passkey login request expired. Generate a new QR code.";
                        AppendDebug("Poll result: request expired.");
                        StateHasChanged();
                    });
                    return;
                }

                await InvokeAsync(() =>
                {
                    PasskeyStatus = $"Waiting for approval. Expires at {request.ExpiresAtUtc.LocalDateTime:t}.";
                    StateHasChanged();
                });

                await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
            AppendDebug("Polling cancelled.");
        }
        catch (Exception ex)
        {
            await InvokeAsync(() =>
            {
                AppendDebug($"Polling failed: {ex.Message}");
                PasskeyStatus = $"Phone-login polling failed: {ex.Message}";
                StateHasChanged();
            });
        }
    }

    private void AppendDebug(string message)
    {
        var timestamp = DateTimeOffset.Now.ToString("HH:mm:ss");
        DesktopDebugLog = $"[{timestamp}] {message}\n\n{DesktopDebugLog}";
    }

    private static string NormalizeReturnUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !value.StartsWith('/') || value.StartsWith("//", StringComparison.Ordinal))
        {
            return "/manage";
        }

        return value;
    }

    public async ValueTask DisposeAsync()
    {
        if (_passkeyPollingCts is not null)
        {
            await _passkeyPollingCts.CancelAsync();
            _passkeyPollingCts.Dispose();
            _passkeyPollingCts = null;
        }
    }
}
