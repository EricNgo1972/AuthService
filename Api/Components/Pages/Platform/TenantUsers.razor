@page "/platform/tenants/{TenantId}/users"
@attribute [Authorize(Policy = "PlatformAdminOnly")]
@inject ITenantService TenantService
@inject ITenantMembershipService TenantMembershipService
@inject IIdentityService IdentityService
@inject IPasswordResetService PasswordResetService
@inject INotificationService NotificationService
@inject NavigationManager NavigationManager

<PageTitle>Tenant Users</PageTitle>

<section class="page">
    <div class="hero">
        <div class="hero-copy stack">
            <p class="eyebrow">Platform Management</p>
            <h1>@_tenantName users</h1>
            <p class="muted">Manage users inside this tenant, assign roles, and send password reset links when needed.</p>
        </div>
        <div class="actions">
            <span class="tag">Total users: @_rows.Count</span>
        </div>
    </div>

    <div class="tenant-toolbar">
        <button class="toolbar-button" @onclick="ToggleCreatePanel">
            <span class="toolbar-icon">+</span>
            <span>@(_showCreatePanel ? "Close" : "Create new user")</span>
        </button>
        <a class="toolbar-button toolbar-button-subtle" href="/platform/tenants">
            <span class="toolbar-icon">&lt;</span>
            <span>Back to tenants</span>
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert @(_success ? "success" : "error")">@_message</div>
    }

    @if (_busy)
    {
        <div class="activity-indicator" role="status" aria-live="polite">
            <span class="spinner" aria-hidden="true"></span>
            <div>
                <strong>@_busyTitle</strong>
                <div class="muted">@_busyMessage</div>
            </div>
        </div>
    }
    else if (_loading)
    {
        <div class="activity-indicator page-loading" role="status" aria-live="polite">
            <span class="spinner" aria-hidden="true"></span>
            <div>
                <strong>Loading users</strong>
                <div class="muted">Retrieving the users assigned to this tenant.</div>
            </div>
        </div>
    }

    @if (_showCreatePanel)
    {
        <div class="panel stack">
            <p class="eyebrow">Create User</p>
            <h1>Add user to @_tenantName</h1>

            <EditForm Model="_createModel" OnValidSubmit="CreateUserAsync" class="stack">
                <DataAnnotationsValidator />
                <ValidationSummary />
                <label class="field">
                    <span>Display Name</span>
                    <InputText @bind-Value="_createModel.DisplayName" />
                </label>
                <label class="field">
                    <span>Email</span>
                    <InputText @bind-Value="_createModel.Email" />
                </label>
                <label class="field">
                    <span>Temporary Password</span>
                    <InputText @bind-Value="_createModel.Password" type="password" />
                </label>
                <label class="field">
                    <span>Role</span>
                    <InputSelect @bind-Value="_createModel.Role">
                        <option value="@SystemRoles.User">User</option>
                        <option value="@SystemRoles.Admin">Admin</option>
                    </InputSelect>
                </label>
                <button class="button primary" type="submit" disabled="@_busy">Create user</button>
            </EditForm>
        </div>
    }

    <div class="table-shell">
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Platform Role</th>
                    <th>Tenant Role</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (_rows.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="empty-state muted">No users found for this tenant.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>
                                <strong>@row.DisplayName</strong>
                                <div class="muted">@row.Email</div>
                                <div class="muted">@row.UserId</div>
                            </td>
                            <td>@row.PlatformRole</td>
                            <td>
                                <InputSelect @bind-Value="row.Role">
                                    <option value="@SystemRoles.User">User</option>
                                    <option value="@SystemRoles.Admin">Admin</option>
                                </InputSelect>
                            </td>
                            <td>
                                <span class="tag @(row.IsActive ? null : "inactive")">@(row.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td>
                                <div class="row-actions">
                                    <button class="secondary" @onclick="() => UpdateRoleAsync(row)">Save Role</button>
                                    <button class="warning" @onclick="() => ToggleStatusAsync(row)">@(row.IsActive ? "Disable" : "Enable")</button>
                                    <button class="danger" @onclick="() => SendResetAsync(row)">Send Reset</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

@code {
    [Parameter]
    public string TenantId { get; set; } = string.Empty;

    private readonly CreateUserModel _createModel = new();
    private readonly List<TenantUserRow> _rows = [];
    private string _tenantName = "Tenant";
    private bool _busy;
    private bool _loading = true;
    private bool _showCreatePanel;
    private bool _success;
    private string? _message;
    private string _busyTitle = "Working";
    private string _busyMessage = "Updating tenant users.";

    protected override async Task OnParametersSetAsync()
    {
        var tenant = await TenantService.GetByIdAsync(TenantId);
        _tenantName = tenant?.Name ?? TenantId;
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _loading = true;
        try
        {
            _rows.Clear();
            var memberships = await TenantMembershipService.ListByTenantAsync(TenantId);
            foreach (var membership in memberships)
            {
                var user = await IdentityService.GetByIdAsync(membership.UserId);
                if (user is null)
                {
                    continue;
                }

                _rows.Add(new TenantUserRow
                {
                    UserId = user.UserId,
                    DisplayName = user.DisplayName,
                    Email = user.Email,
                    PlatformRole = user.Role,
                    Role = membership.Role,
                    IsActive = membership.IsActive
                });
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateUserAsync()
    {
        _busy = true;
        _message = null;
        _success = false;
        _busyTitle = "Creating user";
        _busyMessage = "Provisioning the account and attaching it to this tenant.";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        try
        {
            var result = await TenantMembershipService.AddUserToTenantAsync(TenantId, _createModel.DisplayName, _createModel.Email, _createModel.Password, _createModel.Role, true);
            if (!result.Succeeded)
            {
                _message = result.ErrorMessage ?? "Create user failed.";
                return;
            }

            _success = true;
            _message = "User assigned to tenant.";
            _createModel.DisplayName = string.Empty;
            _createModel.Email = string.Empty;
            _createModel.Password = string.Empty;
            _createModel.Role = SystemRoles.User;
            _showCreatePanel = false;
            await LoadUsersAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task UpdateRoleAsync(TenantUserRow row)
    {
        _busy = true;
        _busyTitle = "Saving role";
        _busyMessage = $"Updating the tenant role for {row.Email}.";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        try
        {
            var result = await TenantMembershipService.ChangeRoleAsync(TenantId, row.UserId, row.Role);
            _success = result.Succeeded;
            _message = result.Succeeded ? $"Updated role for {row.Email}." : result.ErrorMessage ?? "Role update failed.";
            await LoadUsersAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ToggleStatusAsync(TenantUserRow row)
    {
        _busy = true;
        _busyTitle = row.IsActive ? "Disabling user" : "Enabling user";
        _busyMessage = $"Updating account access for {row.Email}.";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        try
        {
            var result = await TenantMembershipService.ChangeStatusAsync(TenantId, row.UserId, !row.IsActive);
            _success = result.Succeeded;
            _message = result.Succeeded ? $"Updated status for {row.Email}." : result.ErrorMessage ?? "Status update failed.";
            await LoadUsersAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SendResetAsync(TenantUserRow row)
    {
        _busy = true;
        _busyTitle = "Sending reset";
        _busyMessage = $"Creating a reset request for {row.Email}.";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        try
        {
            var reset = await PasswordResetService.CreateResetRequestAsync(row.Email);
            if (reset.Created && reset.ResetToken is not null && reset.ExpiresAtUtc.HasValue && reset.User is not null)
            {
                var resetUrl = $"{NavigationManager.BaseUri.TrimEnd('/')}/reset-password?token={Uri.EscapeDataString(reset.ResetToken)}";
                await NotificationService.SendPasswordResetAsync(reset.User, _tenantName, reset.ResetToken, resetUrl, reset.ExpiresAtUtc.Value);
                _success = true;
                _message = $"Password reset email sent to {row.Email}.";
                return;
            }

            _success = false;
            _message = "Password reset request failed.";
        }
        finally
        {
            _busy = false;
        }
    }

    private void ToggleCreatePanel()
    {
        _showCreatePanel = !_showCreatePanel;
    }

    private sealed class CreateUserModel
    {
        [Required]
        public string DisplayName { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        [Required]
        public string Role { get; set; } = SystemRoles.User;
    }

    private sealed class TenantUserRow
    {
        public string UserId { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PlatformRole { get; set; } = SystemRoles.User;
        public string Role { get; set; } = SystemRoles.User;
        public bool IsActive { get; set; }
    }
}
