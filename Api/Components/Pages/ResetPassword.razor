@page "/reset-password"
@attribute [AllowAnonymous]
@inject IPasswordResetService PasswordResetService
@inject IIdentityService IdentityService
@inject IPasswordService PasswordService
@inject ISessionService SessionService
@inject IAuditService AuditService
@inject NavigationManager NavigationManager

<PageTitle>Reset Password</PageTitle>

<section class="page narrow">
    <div class="panel stack">
        <p class="eyebrow">Reset Password</p>
        <h1>Set a new password</h1>
        <p class="muted">Use the secure token from the email you received for your account.</p>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert @(_successful ? "success" : "error")">@_message</div>
        }

        @if (_submitting)
        {
            <div class="activity-indicator page-loading" role="status" aria-live="polite">
                <span class="spinner" aria-hidden="true"></span>
                <div>
                    <strong>Resetting password</strong>
                    <div class="muted">Validating the token, updating the password, and revoking old sessions.</div>
                </div>
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" class="stack">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <label class="field">
                <span>Reset Token</span>
                <InputText @bind-Value="_model.ResetToken" />
            </label>
            <label class="field">
                <span>New Password</span>
                <InputText @bind-Value="_model.NewPassword" type="password" />
            </label>
            <button class="button primary" type="submit" disabled="@_submitting">Reset password</button>
        </EditForm>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private readonly ResetPasswordModel _model = new();
    private bool _submitting;
    private bool _successful;
    private string? _message;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Token))
        {
            _model.ResetToken = Token;
        }
    }

    private async Task HandleSubmitAsync()
    {
        _submitting = true;
        _successful = false;
        _message = null;

        try
        {
            var resetRequest = await PasswordResetService.ConsumeResetTokenAsync(_model.ResetToken);
            if (!resetRequest.Succeeded || resetRequest.Value is null)
            {
                _message = resetRequest.ErrorMessage ?? "Reset failed.";
                return;
            }

            var policy = await PasswordService.ValidatePolicyAsync(_model.NewPassword);
            if (!policy.Succeeded)
            {
                _message = policy.ErrorMessage ?? "Invalid password.";
                return;
            }

            var user = await IdentityService.GetByIdAsync(resetRequest.Value.UserId);
            if (user is null)
            {
                _message = "Reset failed.";
                return;
            }

            var hash = await PasswordService.HashPasswordAsync(_model.NewPassword);
            await IdentityService.UpdatePasswordAsync(user, hash);
            await SessionService.RevokeAllSessionsAsync(user);
            await AuditService.LogEventAsync("SYSTEM", user.UserId, "reset_password_ui", "success", null, null, null);
            _successful = true;
            _message = "Password has been reset. Redirecting to login...";
            await Task.Delay(1200);
            NavigationManager.NavigateTo("/login?message=Password%20has%20been%20reset.", true);
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class ResetPasswordModel
    {
        [Required]
        public string ResetToken { get; set; } = string.Empty;

        [Required]
        public string NewPassword { get; set; } = string.Empty;
    }
}
